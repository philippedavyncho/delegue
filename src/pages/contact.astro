---
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import {
	contactChannels,
	contactDetails,
	serviceAreaCards,
	supportThemes
} from '../data/contact';

const quickStats = [
	{ value: 'Abidjan', label: 'base de coordination' },
	{ value: 'CI', label: 'couverture prioritaire' },
	{ value: 'Rapide', label: 'premier retour via WhatsApp' }
];

const responseFlow = [
	{
		title: 'Vous nous contactez',
		text: 'Expliquez votre besoin par WhatsApp, téléphone ou email, même de façon simple.'
	},
	{
		title: 'Nous orientons votre demande',
		text: "Représentation, réglementaire, formation ou accompagnement commercial : nous vous dirigeons vers le bon point d'entrée."
	},
	{
		title: 'Nous construisons la suite',
		text: 'Une fois le besoin compris, nous proposons un échange ou un cadre de travail adapté.'
	}
];

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Accueil',
			item: 'https://dasmarkpharma.ci/'
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Contact',
			item: 'https://dasmarkpharma.ci/contact/'
		}
	]
};

const contactSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: contactDetails.companyName,
	url: 'https://dasmarkpharma.ci',
	email: contactDetails.email,
	telephone: '+2250749942744',
	address: {
		'@type': 'PostalAddress',
		streetAddress: contactDetails.addressLine,
		addressLocality: contactDetails.city,
		addressCountry: 'CI'
	},
	contactPoint: [
		{
			'@type': 'ContactPoint',
			telephone: '+2250749942744',
			contactType: 'customer service',
			areaServed: ['Abidjan', "Côte d'Ivoire", "Afrique de l'Ouest"],
			availableLanguage: ['French']
		}
	]
};
---

<Layout
	title="Contact DASMARK PHARMA | Abidjan et Côte d'Ivoire"
	description="Contactez DASMARK PHARMA à Abidjan pour vos projets de promotion médicale, représentation de laboratoires, affaires réglementaires et accompagnement en Côte d'Ivoire."
	canonical="https://dasmarkpharma.ci/contact/"
	structuredData={[contactSchema, breadcrumbSchema]}
>
	<Header />
	<main id="top">
		<section class="contact-page section">
			<div class="container contact-page-shell">
				<div class="contact-hero">
					<div class="contact-copy">
						<span class="page-kicker">Contact</span>
						<h1>Parlons de votre projet pharmaceutique depuis Abidjan vers toute la Côte d'Ivoire.</h1>
						<p class="contact-lead">
							Que vous cherchiez un relais terrain, un accompagnement réglementaire, une
							représentation de laboratoire ou une formation, cette page vous donne un accès
							simple à l'équipe Dasmark Pharma. Le point d'entrée est clair, le contact est
							direct et les zones desservies sont mieux mises en valeur.
						</p>

						<div class="hero-actions">
							<a class="hero-btn" href={contactDetails.whatsappHref}>Écrire sur WhatsApp</a>
							<a class="hero-btn hero-btn-alt" href={contactDetails.phoneHref}>Appeler l'équipe</a>
						</div>

						<div class="quick-stats" aria-label="Infos rapides">
							{
								quickStats.map((stat) => (
									<article class="stat-card">
										<strong>{stat.value}</strong>
										<span>{stat.label}</span>
									</article>
								))
							}
						</div>
					</div>

					<div class="contact-aside">
						<article class="address-card">
							<span class="card-kicker">Base locale</span>
							<h2>{contactDetails.companyName}</h2>
							<p>{contactDetails.tagline}</p>
							<div class="address-list">
								<a class="address-item" href={contactDetails.phoneHref}>
									<strong>Téléphone</strong>
									<span>{contactDetails.phoneDisplay}</span>
								</a>
								<a class="address-item" href={`mailto:${contactDetails.email}`}>
									<strong>Email</strong>
									<span>{contactDetails.email}</span>
								</a>
								<div class="address-item">
									<strong>Adresse</strong>
									<span>{contactDetails.fullAddress}</span>
								</div>
							</div>
						</article>

						<div class="channel-stack">
							{
								contactChannels.map((channel) => (
									<a class:list={['channel-card', channel.toneClass]} href={channel.href}>
										<div>
											<strong>{channel.name}</strong>
											<span>{channel.value}</span>
										</div>
										<p>{channel.note}</p>
									</a>
								))
							}
						</div>
					</div>
				</div>

				<div class="section-heading">
					<span class="section-kicker">Zones desservies</span>
					<h2>Une présence claire à Abidjan, avec un accompagnement qui s'étend à la Côte d'Ivoire.</h2>
					<p>
						Plutôt qu'une ligne perdue dans une liste, les zones couvertes deviennent ici un
						vrai repère. Cela permet de comprendre d'un coup d'œil où Dasmark Pharma agit et
						comment entrer par le bon territoire.
					</p>
				</div>

				<div class="area-grid">
					{
						serviceAreaCards.map((area) => (
							<article class="area-card">
								<div class="area-card-head">
									<span class="card-kicker">{area.label}</span>
									<h3>{area.title}</h3>
								</div>
								<p>{area.description}</p>
								<ul class="area-points">
									{
										area.points.map((point) => (
											<li>{point}</li>
										))
									}
								</ul>
								<a class="area-link" href={area.href}>Explorer cette zone</a>
							</article>
						))
					}
				</div>

				<div class="support-shell">
					<div class="support-copy">
						<span class="section-kicker">Vos besoins</span>
						<h2>Vous pouvez nous contacter pour des demandes très concrètes.</h2>
						<p>
							Nous savons qu'un premier message doit aller vite. Vous pouvez simplement nous
							indiquer votre besoin, votre zone cible et le type d'accompagnement recherché.
							Nous reprenons ensuite la demande avec vous.
						</p>

						<div class="theme-cloud" aria-label="Themes de contact">
							{
								supportThemes.map((theme) => (
									<span>{theme}</span>
								))
							}
						</div>
					</div>

					<div class="flow-grid">
						{
							responseFlow.map((item, index) => (
								<article class="flow-card">
									<span class="flow-index">0{index + 1}</span>
									<h3>{item.title}</h3>
									<p>{item.text}</p>
								</article>
							))
						}
					</div>
				</div>

				<div class="contact-cta">
					<div>
						<span class="section-kicker">Passons à l'action</span>
						<h2>Un message suffit pour lancer la conversation.</h2>
						<p>
							Si vous ne savez pas encore quel service choisir, écrivez-nous simplement votre
							contexte. Nous vous aiderons à prendre le bon point d'entrée entre Abidjan et la
							Côte d'Ivoire.
						</p>
					</div>

					<div class="cta-actions">
						<a class="hero-btn" href={contactDetails.whatsappHref}>Démarrer sur WhatsApp</a>
						<a class="hero-btn hero-btn-alt" href="/services/">Voir les services</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.contact-page {
		padding-top: 1.05rem;
	}

	.contact-page-shell {
		position: relative;
		padding: 1.45rem 1.3rem 1.9rem;
		border-radius: 3rem;
		background: rgba(255, 255, 255, 0.62);
		border: 1px solid rgba(255, 255, 255, 0.84);
		box-shadow:
			0 30px 82px rgba(136, 143, 205, 0.16),
			inset 0 1px 0 rgba(255, 255, 255, 0.88);
		overflow: hidden;
	}

	.contact-page-shell::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			radial-gradient(40% 48% at 12% 12%, rgba(123, 173, 255, 0.18), transparent 72%),
			radial-gradient(34% 44% at 96% 82%, rgba(190, 166, 255, 0.18), transparent 72%);
		pointer-events: none;
	}

	.contact-hero,
	.section-heading,
	.area-grid,
	.support-shell,
	.contact-cta {
		position: relative;
		z-index: 1;
	}

	.contact-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.04fr) minmax(320px, 0.96fr);
		gap: 1.1rem;
		align-items: start;
	}

	.page-kicker,
	.section-kicker,
	.card-kicker {
		display: inline-flex;
		align-items: center;
		padding: 0.4rem 0.76rem;
		border-radius: 999px;
		font-size: 0.8rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.page-kicker,
	.section-kicker {
		background: rgba(255, 255, 255, 0.82);
		border: 1px solid rgba(152, 171, 234, 0.34);
		box-shadow: 0 10px 24px rgba(118, 130, 198, 0.08);
		color: #0e5ea8;
	}

	.card-kicker {
		background: rgba(255, 255, 255, 0.16);
		border: 1px solid rgba(255, 255, 255, 0.22);
		color: rgba(255, 255, 255, 0.9);
	}

	.contact-copy h1,
	.address-card h2,
	.section-heading h2,
	.support-copy h2,
	.contact-cta h2,
	.area-card h3 {
		margin: 0;
		font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
		line-height: 1.03;
		letter-spacing: -0.05em;
	}

	.contact-copy h1 {
		margin-top: 0.95rem;
		font-size: clamp(2.4rem, 5vw, 4.2rem);
		color: #30449f;
		max-width: 12ch;
	}

	.contact-lead,
	.section-heading p,
	.support-copy p,
	.contact-cta p,
	.area-card p,
	.address-card p,
	.channel-card p,
	.flow-card p {
		margin: 0.95rem 0 0;
		color: #556286;
		line-height: 1.75;
	}

	.hero-actions,
	.cta-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.2rem;
	}

	.hero-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.82rem 1.2rem;
		border-radius: 999px;
		background: linear-gradient(135deg, #365bc8, #1f8ccb);
		color: #fff;
		font-weight: 800;
		box-shadow: 0 16px 34px rgba(44, 97, 187, 0.2);
	}

	.hero-btn-alt {
		background: rgba(255, 255, 255, 0.84);
		border: 1px solid rgba(173, 187, 236, 0.6);
		color: #3056a7;
		box-shadow: 0 14px 28px rgba(118, 130, 198, 0.08);
	}

	.quick-stats {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.85rem;
		margin-top: 1.35rem;
	}

	.stat-card {
		padding: 1rem 1.05rem;
		border-radius: 1.4rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(246, 249, 255, 0.84));
		border: 1px solid rgba(219, 226, 245, 0.94);
		box-shadow:
			0 18px 40px rgba(114, 123, 180, 0.1),
			inset 0 1px 0 rgba(255, 255, 255, 0.98);
	}

	.stat-card strong,
	.stat-card span {
		display: block;
	}

	.stat-card strong {
		font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
		font-size: clamp(1.45rem, 2.8vw, 2.2rem);
		line-height: 1;
		color: #30449f;
	}

	.stat-card span {
		margin-top: 0.38rem;
		color: #66739e;
		font-size: 0.92rem;
	}

	.contact-aside {
		display: grid;
		gap: 1rem;
	}

	.address-card {
		padding: 1.35rem 1.2rem;
		border-radius: 2rem;
		background:
			radial-gradient(circle at top right, rgba(255, 255, 255, 0.16), transparent 28%),
			linear-gradient(145deg, rgba(83, 108, 220, 0.96), rgba(116, 106, 222, 0.93) 54%, rgba(83, 176, 225, 0.9));
		color: #fff;
		box-shadow: 0 24px 52px rgba(110, 114, 197, 0.2);
	}

	.address-card h2 {
		margin-top: 0.9rem;
		font-size: clamp(1.8rem, 3vw, 2.35rem);
		color: #fff;
	}

	.address-card p {
		color: rgba(255, 255, 255, 0.92);
	}

	.address-list {
		display: grid;
		gap: 0.8rem;
		margin-top: 1.05rem;
	}

	.address-item {
		display: block;
		padding: 0.9rem 0.95rem;
		border-radius: 1.3rem;
		background: rgba(255, 255, 255, 0.12);
		border: 1px solid rgba(255, 255, 255, 0.16);
	}

	.address-item strong,
	.address-item span,
	.channel-card strong,
	.channel-card span {
		display: block;
	}

	.address-item strong {
		font-size: 0.82rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.84);
	}

	.address-item span {
		margin-top: 0.24rem;
		color: #fff;
		font-weight: 700;
		line-height: 1.55;
	}

	.channel-stack {
		display: grid;
		gap: 0.85rem;
	}

	.channel-card {
		padding: 1.05rem 1rem;
		border-radius: 1.6rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(248, 250, 255, 0.9));
		border: 1px solid rgba(214, 223, 246, 0.92);
		box-shadow:
			0 22px 46px rgba(109, 117, 174, 0.12),
			inset 0 1px 0 rgba(255, 255, 255, 0.96);
	}

	.channel-card strong {
		font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
		font-size: 1.2rem;
		color: #30449f;
	}

	.channel-card span {
		margin-top: 0.2rem;
		color: #0e5ea8;
		font-weight: 800;
	}

	.channel-card p {
		margin-top: 0.65rem;
	}

	.channel-card.is-success {
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 255, 248, 0.94)),
			linear-gradient(90deg, rgba(43, 197, 97, 0.08), rgba(255, 255, 255, 0));
	}

	.channel-card.is-info {
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 251, 255, 0.94)),
			linear-gradient(90deg, rgba(57, 127, 227, 0.08), rgba(255, 255, 255, 0));
	}

	.channel-card.is-violet {
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(251, 248, 255, 0.94)),
			linear-gradient(90deg, rgba(140, 112, 224, 0.08), rgba(255, 255, 255, 0));
	}

	.section-heading {
		max-width: 52rem;
		margin-top: 1.95rem;
	}

	.section-heading h2,
	.support-copy h2,
	.contact-cta h2 {
		margin-top: 0.85rem;
		font-size: clamp(2rem, 4vw, 3.1rem);
		color: #30449f;
	}

	.area-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.2rem;
	}

	.area-card {
		position: relative;
		padding: 1.3rem 1.2rem 1.25rem;
		border-radius: 2rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 249, 255, 0.9));
		border: 1px solid rgba(219, 226, 245, 0.98);
		box-shadow:
			0 24px 48px rgba(115, 122, 180, 0.1),
			inset 0 1px 0 rgba(255, 255, 255, 0.98);
		overflow: hidden;
	}

	.area-card::before {
		content: '';
		position: absolute;
		inset: 0 0 auto 0;
		height: 4px;
		background: linear-gradient(90deg, rgba(72, 112, 219, 0.92), rgba(108, 194, 231, 0.82));
	}

	.area-card-head {
		display: grid;
		gap: 0.8rem;
	}

	.area-card .card-kicker {
		background: rgba(14, 94, 168, 0.08);
		border: 1px solid rgba(14, 94, 168, 0.12);
		color: #0e5ea8;
	}

	.area-card h3 {
		font-size: clamp(1.6rem, 2.4vw, 2.2rem);
		color: #30449f;
	}

	.area-points {
		display: grid;
		gap: 0.78rem;
		padding: 0;
		margin: 1rem 0 0;
		list-style: none;
	}

	.area-points li {
		display: flex;
		gap: 0.7rem;
		align-items: flex-start;
		color: #44517d;
	}

	.area-points li::before,
	.theme-cloud span::before {
		content: '+';
		flex: 0 0 auto;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.55rem;
		height: 1.55rem;
		border-radius: 999px;
		background: rgba(118, 194, 255, 0.16);
		color: #4ea5f0;
		font-weight: 800;
	}

	.area-link {
		display: inline-flex;
		align-items: center;
		margin-top: 1.05rem;
		color: #2f6bc0;
		font-weight: 800;
	}

	.support-shell {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
		gap: 1rem;
		margin-top: 1.95rem;
	}

	.support-copy {
		padding: 1.35rem 1.25rem;
		border-radius: 2rem;
		background: rgba(255, 255, 255, 0.58);
		border: 1px solid rgba(255, 255, 255, 0.82);
		box-shadow: 0 18px 44px rgba(118, 126, 182, 0.08);
	}

	.theme-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 1.15rem;
	}

	.theme-cloud span {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.72rem 0.86rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.86);
		border: 1px solid rgba(210, 220, 244, 0.92);
		color: #496085;
		font-size: 0.94rem;
		font-weight: 700;
	}

	.theme-cloud span::before {
		width: 1.35rem;
		height: 1.35rem;
		font-size: 0.8rem;
	}

	.flow-grid {
		display: grid;
		gap: 0.9rem;
	}

	.flow-card {
		padding: 1.2rem 1.15rem;
		border-radius: 1.7rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 255, 0.9));
		border: 1px solid rgba(214, 223, 246, 0.92);
		box-shadow:
			0 20px 42px rgba(109, 117, 174, 0.1),
			inset 0 1px 0 rgba(255, 255, 255, 0.96);
	}

	.flow-index {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.6rem;
		height: 2.6rem;
		border-radius: 999px;
		background: linear-gradient(135deg, #5c78e1, #63c2ef);
		color: #fff;
		font-weight: 800;
	}

	.flow-card h3 {
		margin: 0.85rem 0 0;
		font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
		font-size: 1.22rem;
		color: #30449f;
	}

	.flow-card p {
		margin-top: 0.45rem;
	}

	.contact-cta {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1rem;
		align-items: end;
		margin-top: 1.95rem;
		padding: 1.35rem 1.2rem;
		border-radius: 2rem;
		background: rgba(255, 255, 255, 0.56);
		border: 1px solid rgba(255, 255, 255, 0.8);
		box-shadow: 0 18px 44px rgba(118, 126, 182, 0.08);
	}

	.cta-actions {
		margin-top: 0;
		justify-content: flex-end;
	}

	@media (max-width: 980px) {
		.contact-hero,
		.support-shell,
		.contact-cta {
			grid-template-columns: 1fr;
		}

		.area-grid {
			grid-template-columns: 1fr;
		}

		.cta-actions {
			justify-content: flex-start;
		}
	}

	@media (max-width: 720px) {
		.quick-stats {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.contact-page-shell {
			padding: 1rem;
			border-radius: 1.7rem;
		}

		.address-card,
		.channel-card,
		.area-card,
		.support-copy,
		.flow-card,
		.contact-cta {
			border-radius: 1.4rem;
		}

		.contact-copy h1 {
			max-width: none;
		}

		.stat-card {
			padding: 0.9rem;
		}

		.hero-actions,
		.cta-actions {
			flex-direction: column;
			align-items: stretch;
		}
	}
</style>
