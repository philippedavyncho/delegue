---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const contactSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: 'DASMARK PHARMA',
	url: 'https://dasmarkpharma.ci',
	contactPoint: [
		{
			'@type': 'ContactPoint',
			telephone: '+2250749942744',
			contactType: 'customer service',
			areaServed: ['Abidjan', 'Cote d Ivoire', 'Afrique de l Ouest'],
			availableLanguage: ['French']
		}
	]
};
---

<Layout
	title="Contact DASMARK PHARMA | Distribution pharma CI"
	description="Contactez DASMARK PHARMA a Abidjan pour vos besoins de distribution pharmaceutique B2B en Cote d Ivoire et en Afrique de l Ouest."
	canonical="https://dasmarkpharma.ci/contact/"
	structuredData={contactSchema}
>
	<Header />
	<main id="top">
		<section class="section">
			<div class="container seo-page">
				<h1>Contact DASMARK PHARMA</h1>
				<p>
					Parlez avec notre equipe pour vos besoins de grossiste pharmaceutique Cote d Ivoire
					et de distribution medicaments Abidjan.
				</p>

				<h2>Coordonnees entreprise</h2>
				<ul>
					<li>Adresse: Cocody Angre Djrorobite 2, derriere la pharmacie Sainte Clementine, Abidjan.</li>
					<li>Telephone: +225 07 49 94 27 44.</li>
					<li>Zones desservies: Abidjan, Cote d Ivoire, Afrique de l Ouest.</li>
				</ul>

				<h2>Demande rapide</h2>
				<p>
					Le moyen le plus rapide est WhatsApp. Nous accompagnons pharmacies,
					hopitaux, cliniques et laboratoires.
				</p>

				<div class="seo-cta-row">
					<a class="seo-btn" href="https://wa.me/2250749942744">Parler sur WhatsApp</a>
					<a class="seo-btn seo-btn-alt" href="/services/">Voir les services</a>
					<a class="seo-btn seo-btn-alt" href="/produits/">Voir les produits</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.seo-page h1,
	.seo-page h2 {
		line-height: 1.25;
	}

	.seo-page h1 {
		margin-bottom: 0.8rem;
	}

	.seo-page h2 {
		margin-top: 1.6rem;
		margin-bottom: 0.6rem;
	}

	.seo-page p {
		margin: 0;
		max-width: 70ch;
	}

	.seo-page ul {
		margin: 0;
		padding-left: 1.2rem;
		max-width: 70ch;
	}

	.seo-page li {
		margin-bottom: 0.35rem;
	}

	.seo-cta-row {
		display: flex;
		gap: 0.8rem;
		margin-top: 1.6rem;
		flex-wrap: wrap;
	}

	.seo-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.7rem 1.1rem;
		border-radius: 999px;
		background: #0e5ea8;
		color: #fff;
		font-weight: 700;
	}

	.seo-btn-alt {
		background: #fff;
		color: #0e5ea8;
	}
</style>
