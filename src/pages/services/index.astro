---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

const serviceSchema = {
	'@context': 'https://schema.org',
	'@type': 'Service',
	name: 'Services pour laboratoires pharmaceutiques',
	serviceType: 'Marketing pharmaceutique, promotion medicale et visite medicale',
	provider: {
		'@type': 'Organization',
		name: 'DASMARK PHARMA',
		url: 'https://dasmarkpharma.ci'
	},
	areaServed: ['Abidjan', 'Cote d Ivoire', 'Afrique francophone']
};
---

<Layout
	title="Services laboratoires pharmaceutiques | DASMARK PHARMA"
	description="Services de marketing pharmaceutique, promotion medicale et visite medicale en Cote d Ivoire."
	canonical="https://dasmarkpharma.ci/services/"
	structuredData={serviceSchema}
>
	<Header />
	<main id="top">
		<section class="section">
			<div class="container seo-page">
				<h1>Services pour laboratoires pharmaceutiques</h1>
				<p>
					DASMARK PHARMA accompagne les laboratoires pour accelerer leur impact terrain
					en Cote d Ivoire et en Afrique francophone.
				</p>

				<h2>Marketing pharmaceutique et promotion medicale</h2>
				<p>
					Nous structurons vos actions de promotion medicale avec une execution orientee
					resultats.
				</p>

				<h2>Visite medicale et deployment terrain</h2>
				<p>
					Nous renforcons la couverture medecins et pharmacies avec un pilotage KPI clair.
				</p>

				<h2>Accompagnement des equipes et formation</h2>
				<p>
					Notre accompagnement combine formation delegue medical et coaching terrain.
				</p>

				<div class="seo-cta-row">
					<a class="seo-btn" href="https://wa.me/2250749942744">Parler sur WhatsApp</a>
					<a class="seo-btn seo-btn-alt" href="/formation/">Voir la formation</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.seo-page h1,
	.seo-page h2 {
		line-height: 1.25;
	}

	.seo-page h1 {
		margin-bottom: 0.8rem;
	}

	.seo-page h2 {
		margin-top: 1.6rem;
		margin-bottom: 0.6rem;
	}

	.seo-page p {
		margin: 0;
		max-width: 70ch;
	}

	.seo-cta-row {
		display: flex;
		gap: 0.8rem;
		margin-top: 1.6rem;
		flex-wrap: wrap;
	}

	.seo-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.7rem 1.1rem;
		border-radius: 999px;
		background: #0e5ea8;
		color: #fff;
		font-weight: 700;
	}

	.seo-btn-alt {
		background: #fff;
		color: #0e5ea8;
	}
</style>
