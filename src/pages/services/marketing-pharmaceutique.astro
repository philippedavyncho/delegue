---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

const serviceSchema = {
	'@context': 'https://schema.org',
	'@type': 'Service',
	name: "Marketing pharmaceutique en Côte d'Ivoire",
	serviceType: 'Accompagnement des laboratoires pharmaceutiques',
	provider: {
		'@type': 'Organization',
		name: 'DASMARK PHARMA',
		url: 'https://dasmarkpharma.ci'
	},
	areaServed: ['Abidjan', "Côte d'Ivoire"]
};
---

<Layout
	title="Marketing pharmaceutique CI | DASMARK PHARMA"
	description="Stratégie et exécution marketing pharmaceutique pour laboratoires en Côte d'Ivoire, avec déploiement terrain à Abidjan et en Afrique de l'Ouest."
	canonical="https://dasmarkpharma.ci/services/marketing-pharmaceutique/"
	structuredData={serviceSchema}
>
	<Header />
	<main id="top">
		<section class="section">
			<div class="container seo-page">
				<h1>Marketing pharmaceutique en Côte d'Ivoire</h1>
				<p>
					DASMARK PHARMA accompagne les laboratoires avec un dispositif de marketing
					pharmaceutique relié aux objectifs de visibilité, de représentation et de présence terrain.
				</p>

				<h2>Stratégie commerciale et pénétration du marché</h2>
				<p>
					Nous définissons le ciblage médical, les messages scientifiques et les priorités de
					déploiement par zone.
				</p>

				<h2>Activation terrain B2B</h2>
				<p>
					Nos équipes exécutent des plans d'action pour médecins, pharmacies,
					hôpitaux et cliniques en Côte d'Ivoire.
				</p>

				<h2>Pilotage de performance</h2>
				<p>
					Suivi KPI, ajustements rapides et alignement avec votre stratégie de développement
					pharmaceutique en Côte d'Ivoire et en Afrique de l'Ouest.
				</p>

				<div class="seo-cta-row">
					<a class="seo-btn" href="https://wa.me/2250749942744">Demander un devis laboratoire</a>
					<a class="seo-btn seo-btn-alt" href="/services/">Voir tous les services</a>
					<a class="seo-btn seo-btn-alt" href="/contact/">Prendre un rendez-vous</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.seo-page h1,
	.seo-page h2 {
		line-height: 1.25;
	}

	.seo-page h1 {
		margin-bottom: 0.8rem;
	}

	.seo-page h2 {
		margin-top: 1.6rem;
		margin-bottom: 0.6rem;
	}

	.seo-page p {
		margin: 0;
		max-width: 70ch;
	}

	.seo-cta-row {
		display: flex;
		gap: 0.8rem;
		margin-top: 1.6rem;
		flex-wrap: wrap;
	}

	.seo-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.7rem 1.1rem;
		border-radius: 999px;
		background: #0e5ea8;
		color: #fff;
		font-weight: 700;
	}

	.seo-btn-alt {
		background: #fff;
		color: #0e5ea8;
	}
</style>
