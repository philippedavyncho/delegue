---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

const localServiceSchema = {
	'@context': 'https://schema.org',
	'@type': 'Service',
	name: 'Distribution pharmaceutique a Abidjan',
	serviceType: 'Grossiste pharmaceutique et accompagnement laboratoires',
	provider: {
		'@type': 'Organization',
		name: 'DASMARK PHARMA',
		url: 'https://dasmarkpharma.ci'
	},
	areaServed: ['Abidjan', 'Cote d Ivoire']
};
---

<Layout
	title="Distribution pharmaceutique Abidjan | DASMARK PHARMA"
	description="Accompagnement B2B de distribution pharmaceutique a Abidjan pour pharmacies, hopitaux, cliniques et laboratoires en Cote d Ivoire."
	canonical="https://dasmarkpharma.ci/zones/abidjan/"
	structuredData={localServiceSchema}
>
	<Header />
	<main id="top">
		<section class="section">
			<div class="container seo-page">
				<h1>Distribution pharmaceutique a Abidjan</h1>
				<p>
					DASMARK PHARMA accompagne les acteurs de sante a Abidjan avec une approche terrain
					orientee resultats et conformite.
				</p>

				<h2>Services B2B pour etablissements de sante</h2>
				<p>
					Distribution medicaments Abidjan, suivi des besoins officinaux et appui aux structures
					hospitalieres et cliniques.
				</p>

				<h2>Accompagnement des laboratoires</h2>
				<p>
					Support au deploiement local et coordination avec les objectifs commerciaux
					en Cote d Ivoire.
				</p>

				<h2>Coordonnees et zones desservies</h2>
				<p>
					Adresse: Cocody Angre Djrorobite 2, derriere la pharmacie Sainte Clementine, Abidjan.
					Telephone: +225 07 49 94 27 44. Zones: Abidjan, Cote d Ivoire, Afrique de l Ouest.
				</p>

				<div class="seo-cta-row">
					<a class="seo-btn" href="https://wa.me/2250749942744">Parler a un expert</a>
					<a class="seo-btn seo-btn-alt" href="/services/">Voir les services</a>
					<a class="seo-btn seo-btn-alt" href="/contact/">Contacter l equipe</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.seo-page h1,
	.seo-page h2 {
		line-height: 1.25;
	}

	.seo-page h1 {
		margin-bottom: 0.8rem;
	}

	.seo-page h2 {
		margin-top: 1.6rem;
		margin-bottom: 0.6rem;
	}

	.seo-page p {
		margin: 0;
		max-width: 70ch;
	}

	.seo-cta-row {
		display: flex;
		gap: 0.8rem;
		margin-top: 1.6rem;
		flex-wrap: wrap;
	}

	.seo-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.7rem 1.1rem;
		border-radius: 999px;
		background: #0e5ea8;
		color: #fff;
		font-weight: 700;
	}

	.seo-btn-alt {
		background: #fff;
		color: #0e5ea8;
	}
</style>
