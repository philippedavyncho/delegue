---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

const localServiceSchema = {
	'@context': 'https://schema.org',
	'@type': 'Service',
	name: 'Marketing pharmaceutique a Abidjan',
	serviceType: 'Accompagnement des laboratoires pharmaceutiques',
	provider: {
		'@type': 'Organization',
		name: 'DASMARK PHARMA',
		url: 'https://dasmarkpharma.ci'
	},
	areaServed: ['Abidjan']
};
---

<Layout
	title="Marketing pharmaceutique a Abidjan | DASMARK PHARMA"
	description="Accompagnement marketing pharmaceutique, visite medicale et formation delegue medical a Abidjan."
	canonical="https://dasmarkpharma.ci/zones/abidjan/"
	structuredData={localServiceSchema}
>
	<Header />
	<main id="top">
		<section class="section">
			<div class="container seo-page">
				<h1>Marketing pharmaceutique a Abidjan</h1>
				<p>
					DASMARK PHARMA accompagne les laboratoires pharmaceutiques a Abidjan avec une
					approche terrain orientee resultats.
				</p>

				<h2>Services B2B pour laboratoires</h2>
				<p>
					Promotion medicale, visite medicale, pilotage de la couverture et plans d action
					par secteur.
				</p>

				<h2>Formation delegue medical a Abidjan</h2>
				<p>
					Nous formons des profils operationnels avec coaching terrain et suivi des acquis.
				</p>

				<h2>Pourquoi choisir DASMARK PHARMA</h2>
				<p>
					Une execution locale, un langage metier pharma et des objectifs de conversion
					clairs.
				</p>

				<div class="seo-cta-row">
					<a class="seo-btn" href="https://wa.me/2250749942744">Parler a un expert</a>
					<a class="seo-btn seo-btn-alt" href="/services/">Voir les services</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.seo-page h1,
	.seo-page h2 {
		line-height: 1.25;
	}

	.seo-page h1 {
		margin-bottom: 0.8rem;
	}

	.seo-page h2 {
		margin-top: 1.6rem;
		margin-bottom: 0.6rem;
	}

	.seo-page p {
		margin: 0;
		max-width: 70ch;
	}

	.seo-cta-row {
		display: flex;
		gap: 0.8rem;
		margin-top: 1.6rem;
		flex-wrap: wrap;
	}

	.seo-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.7rem 1.1rem;
		border-radius: 999px;
		background: #0e5ea8;
		color: #fff;
		font-weight: 700;
	}

	.seo-btn-alt {
		background: #fff;
		color: #0e5ea8;
	}
</style>
