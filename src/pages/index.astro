---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ServicesSection from '../components/ServicesSection.astro';
import AboutSection from '../components/AboutSection.astro';
import TrainingGallerySection from '../components/TrainingGallerySection.astro';
import PartnersSection from '../components/PartnersSection.astro';
import RubriqueSection from '../components/RubriqueSection.astro';
import Loader from '../components/Loader.astro';

const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'LocalBusiness',
	name: 'DASMARK PHARMA',
	url: 'https://dasmarkpharma.ci',
	logo: 'https://dasmarkpharma.ci/logodasm.png',
	telephone: '+2250749942744',
	address: {
		'@type': 'PostalAddress',
		streetAddress: 'Cocody Angré Djorobité 2, derrière la pharmacie Sainte Clémentine',
		addressLocality: 'Abidjan',
		addressCountry: 'CI'
	},
	areaServed: ['Abidjan', "Côte d'Ivoire", "Afrique de l'Ouest"],
	knowsAbout: [
		'promotion médicale et pharmaceutique',
		'représentation de laboratoires pharmaceutiques',
		'affaires réglementaires pharmaceutiques',
		'formation des délégués médicaux'
	]
};

const serviceSchema = {
	'@context': 'https://schema.org',
	'@type': 'Service',
	name: 'Accompagnement pharmaceutique B2B',
	serviceType:
		'Promotion médicale, représentation de laboratoires, affaires réglementaires et formation des délégués médicaux',
	provider: {
		'@type': 'Organization',
		name: 'DASMARK PHARMA',
		url: 'https://dasmarkpharma.ci'
	},
	areaServed: ['Abidjan', "Côte d'Ivoire", "Afrique de l'Ouest"]
};
---

<Layout
	title="Promotion médicale et accompagnement pharmaceutique | DASMARK PHARMA"
	description="DASMARK PHARMA accompagne les laboratoires et acteurs de santé avec la promotion médicale, la représentation, les affaires réglementaires et la formation en Côte d'Ivoire."
	canonical="https://dasmarkpharma.ci/"
	structuredData={[organizationSchema, serviceSchema]}
>
	<Loader />
	<Header />
	<main>
		<Hero />
		<ServicesSection />
		<TrainingGallerySection />
		<AboutSection />
		<PartnersSection />
		<RubriqueSection />
	</main>
</Layout>
