---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ServicesSection from '../components/ServicesSection.astro';
import AboutSection from '../components/AboutSection.astro';
import TrainingGallerySection from '../components/TrainingGallerySection.astro';
import PartnersSection from '../components/PartnersSection.astro';
import RubriqueSection from '../components/RubriqueSection.astro';
import Loader from '../components/Loader.astro';

const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'LocalBusiness',
	name: 'DASMARK PHARMA',
	url: 'https://dasmarkpharma.ci',
	logo: 'https://dasmarkpharma.ci/logodasm.png',
	telephone: '+2250749942744',
	address: {
		'@type': 'PostalAddress',
		streetAddress: 'Cocody Angre Djrorobite 2, derriere la pharmacie Sainte Clementine',
		addressLocality: 'Abidjan',
		addressCountry: 'CI'
	},
	areaServed: ['Abidjan', 'Cote d Ivoire', 'Afrique de l Ouest'],
	knowsAbout: [
		'grossiste pharmaceutique Cote d Ivoire',
		'distribution medicaments Abidjan',
		'fournisseur pharmaceutique Afrique de l Ouest'
	]
};

const serviceSchema = {
	'@context': 'https://schema.org',
	'@type': 'Service',
	name: 'Distribution pharmaceutique B2B',
	serviceType: 'Grossiste pharmaceutique et distribution de medicaments',
	provider: {
		'@type': 'Organization',
		name: 'DASMARK PHARMA',
		url: 'https://dasmarkpharma.ci'
	},
	areaServed: ['Abidjan', 'Cote d Ivoire', 'Afrique de l Ouest']
};
---

<Layout
	title="Grossiste pharmaceutique Cote d Ivoire | DASMARK PHARMA"
	description="DASMARK PHARMA assure la distribution pharmaceutique B2B a Abidjan pour pharmacies, hopitaux, cliniques et laboratoires en Cote d Ivoire."
	canonical="https://dasmarkpharma.ci/"
	structuredData={[organizationSchema, serviceSchema]}
>
	<Loader />
	<Header />
	<main>
		<Hero />
		<ServicesSection />
		<TrainingGallerySection />
		<AboutSection />
		<PartnersSection />
		<RubriqueSection />
	</main>
</Layout>
