---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ServicesSection from '../components/ServicesSection.astro';
import AboutSection from '../components/AboutSection.astro';
import TrainingGallerySection from '../components/TrainingGallerySection.astro';
import PartnersSection from '../components/PartnersSection.astro';
import RubriqueSection from '../components/RubriqueSection.astro';
import Loader from '../components/Loader.astro';

const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'LocalBusiness',
	name: 'DASMARK PHARMA',
	url: 'https://dasmarkpharma.ci',
	logo: 'https://dasmarkpharma.ci/logodasm.png',
	telephone: '+2250749942744',
	address: {
		'@type': 'PostalAddress',
		streetAddress: 'Cocody Angre Djrorobite 2, derriere la pharmacie Sainte Clementine',
		addressLocality: 'Abidjan',
		addressCountry: 'CI'
	},
	areaServed: ['Abidjan', 'Cote d Ivoire', 'Afrique de l Ouest'],
	knowsAbout: [
		'promotion medicale et pharmaceutique',
		'representation de laboratoires pharmaceutiques',
		'affaires reglementaires pharmaceutiques',
		'formation des delegues medicaux'
	]
};

const serviceSchema = {
	'@context': 'https://schema.org',
	'@type': 'Service',
	name: 'Accompagnement pharmaceutique B2B',
	serviceType:
		'Promotion medicale, representation de laboratoires, affaires reglementaires et formation des delegues medicaux',
	provider: {
		'@type': 'Organization',
		name: 'DASMARK PHARMA',
		url: 'https://dasmarkpharma.ci'
	},
	areaServed: ['Abidjan', 'Cote d Ivoire', 'Afrique de l Ouest']
};
---

<Layout
	title="Promotion medicale et accompagnement pharmaceutique | DASMARK PHARMA"
	description="DASMARK PHARMA accompagne les laboratoires et acteurs de sante avec la promotion medicale, la representation, les affaires reglementaires et la formation en Cote d Ivoire."
	canonical="https://dasmarkpharma.ci/"
	structuredData={[organizationSchema, serviceSchema]}
>
	<Loader />
	<Header />
	<main>
		<Hero />
		<ServicesSection />
		<TrainingGallerySection />
		<AboutSection />
		<PartnersSection />
		<RubriqueSection />
	</main>
</Layout>
