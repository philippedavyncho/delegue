---
import Header from '../../components/Header.astro';
import Layout from '../../layouts/Layout.astro';
import { partnerCatalog } from '../../data/partners';

export const getStaticPaths = () =>
	partnerCatalog.map((partner) => ({
		params: { slug: partner.slug },
		props: { partner }
	}));

const { partner } = Astro.props;

const canonical = `https://dasmarkpharma.ci/partenaires/${partner.slug}/`;

const collectionItems = partner.images.map((image, index) => ({
	'@type': 'ListItem',
	position: index + 1,
	name: `Produit ${index + 1} ${partner.shortName}`,
	image: `https://dasmarkpharma.ci${image}`
}));

const partnerSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: `Produits ${partner.shortName}`,
	url: canonical,
	description: partner.seoDescription,
	about: {
		'@type': 'Organization',
		name: partner.name
	},
	mainEntity:
		collectionItems.length > 0
			? {
					'@type': 'ItemList',
					numberOfItems: collectionItems.length,
					itemListElement: collectionItems
				}
			: undefined
};
---

<Layout
	title={`${partner.shortName} | DASMARK PHARMA`}
	description={partner.seoDescription}
	canonical={canonical}
	ogImage={`https://dasmarkpharma.ci${partner.logo}`}
	structuredData={partnerSchema}
>
	<Header />
	<main id="top">
		<section class="section">
			<div class="container partner-page">
				<div class="partner-hero">
					<div class="partner-brand">
						<span class:list={['partner-logo-shell', partner.partnersBadgeClass]}>
							<img src={partner.logo} alt={partner.logoAlt} />
						</span>

						<div class="partner-copy">
							<span class="partner-label">Laboratoire partenaire</span>
							<h1>{partner.name}</h1>
							<p>{partner.intro}</p>
						</div>
					</div>

					<div class="partner-stats">
						<div class="partner-stat">
							<strong>{String(partner.images.length).padStart(2, '0')}</strong>
							<span>{partner.images.length ? 'visuels de produits disponibles' : 'catalogue visuel à venir'}</span>
						</div>
						<div class="partner-stat">
							<strong>{partner.shortName}</strong>
							<span>Catalogue laboratoire</span>
						</div>
					</div>
				</div>

				<div class="partner-products">
					<div class="partner-section-head">
						<h2>Produits du laboratoire</h2>
						<p>Une présentation dédiée aux produits actuellement disponibles pour ce laboratoire partenaire.</p>
					</div>

					{
						partner.images.length > 0 ? (
							<div class="products-grid">
								{
									partner.images.map((image, index) => (
										<article class="product-card">
											<div class="product-media">
												<img
													src={image}
													alt={`Produit ${index + 1} du ${partner.name}`}
													loading={index < 3 ? 'eager' : 'lazy'}
													decoding="async"
												/>
											</div>
											<div class="product-body">
												<strong>{partner.shortName}</strong>
												<small>Produit {String(index + 1).padStart(2, '0')}</small>
											</div>
										</article>
									))
								}
							</div>
						) : (
							<div class="catalog-empty">
								<h2>Catalogue visuel en préparation</h2>
								<p>{partner.emptyStateText}</p>
								<div class="empty-actions">
									<a class="page-btn" href="https://wa.me/2250749942744">Contacter sur WhatsApp</a>
									<a class="page-btn page-btn-alt" href="/contact/">Parler à l'équipe</a>
								</div>
							</div>
						)
					}
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.partner-page {
		display: grid;
		gap: 1.5rem;
	}

	.partner-hero,
	.partner-products,
	.catalog-empty {
		border-radius: 2rem;
		background: rgba(255, 255, 255, 0.76);
		border: 1px solid rgba(255, 255, 255, 0.84);
		box-shadow: 0 24px 60px rgba(130, 137, 194, 0.12);
	}

	.partner-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.4fr) minmax(260px, 0.7fr);
		gap: 1rem;
		padding: 1.35rem;
	}

	.partner-brand {
		display: flex;
		align-items: center;
		gap: 1.2rem;
	}

	.partner-logo-shell {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 7.4rem;
		height: 7.4rem;
		padding: 0.85rem;
		border-radius: 2rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 247, 255, 0.92));
		border: 1px solid rgba(219, 226, 246, 0.95);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.98);
	}

	.partner-logo-shell img {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.partner-badge-alt {
		border-color: rgba(90, 173, 110, 0.42);
	}

	.partner-label {
		display: inline-flex;
		padding: 0.36rem 0.72rem;
		border-radius: 999px;
		background: rgba(82, 107, 193, 0.08);
		color: #4c63b5;
		font-size: 0.8rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.partner-copy h1 {
		margin: 0.9rem 0 0;
		font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1.02;
		letter-spacing: -0.05em;
		color: #324493;
	}

	.partner-copy p,
	.partner-section-head p,
	.catalog-empty p {
		margin: 0.9rem 0 0;
		max-width: 66ch;
		color: #66739e;
	}

	.partner-stats {
		display: grid;
		gap: 0.9rem;
	}

	.partner-stat {
		display: grid;
		gap: 0.28rem;
		padding: 1rem 1.1rem;
		border-radius: 1.5rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(246, 249, 255, 0.88));
		border: 1px solid rgba(224, 231, 246, 0.96);
	}

	.partner-stat strong {
		font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
		font-size: clamp(1.4rem, 2vw, 2rem);
		line-height: 1.05;
		color: #394c93;
	}

	.partner-stat span {
		font-size: 0.92rem;
		color: #7481ab;
	}

	.partner-products {
		padding: 1.35rem;
	}

	.partner-section-head h2,
	.catalog-empty h2 {
		margin: 0;
		font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
		font-size: clamp(1.5rem, 3vw, 2.2rem);
		line-height: 1.08;
		letter-spacing: -0.04em;
		color: #334593;
	}

	.products-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.4rem;
	}

	.product-card {
		border-radius: 1.6rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 249, 255, 0.9));
		border: 1px solid rgba(224, 231, 246, 0.96);
		box-shadow: 0 18px 36px rgba(121, 127, 180, 0.08);
		overflow: hidden;
	}

	.product-media {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1rem;
		aspect-ratio: 4 / 3;
		background: #fff;
	}

	.product-media img {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.product-body {
		display: grid;
		gap: 0.2rem;
		padding: 0.95rem 1rem 1rem;
	}

	.product-body strong {
		font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
		font-size: 1rem;
		color: #3c4f95;
	}

	.product-body small {
		font-size: 0.88rem;
		color: #7783ac;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.catalog-empty {
		margin-top: 1.4rem;
		padding: 1.2rem;
	}

	.empty-actions {
		display: flex;
		gap: 0.8rem;
		margin-top: 1.2rem;
		flex-wrap: wrap;
	}

	.page-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.78rem 1.15rem;
		border-radius: 999px;
		background: #0e5ea8;
		color: #fff;
		font-weight: 700;
	}

	.page-btn-alt {
		background: #fff;
		color: #0e5ea8;
		border: 1px solid rgba(14, 94, 168, 0.14);
	}

	@media (max-width: 960px) {
		.partner-hero {
			grid-template-columns: 1fr;
		}

		.products-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 700px) {
		.products-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.partner-hero,
		.partner-products,
		.catalog-empty {
			padding: 1rem;
			border-radius: 1.45rem;
		}

		.partner-brand {
			flex-direction: column;
			align-items: flex-start;
		}

		.partner-logo-shell {
			width: 6.2rem;
			height: 6.2rem;
			border-radius: 1.5rem;
		}
	}
</style>
