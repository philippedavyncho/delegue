---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const localSchema = {
	'@context': 'https://schema.org',
	'@type': 'Service',
	name: 'Accompagnement pharmaceutique a Abidjan',
	provider: {
		'@type': 'Organization',
		name: 'DASMARK PHARMA',
		url: 'https://dasmarkpharma.ci'
	},
	areaServed: ['Abidjan', 'Cote d Ivoire']
};
---

<Layout
	title="Accompagnement pharmaceutique a Abidjan | DASMARK PHARMA"
	description="DASMARK PHARMA accompagne les laboratoires et acteurs de sante a Abidjan avec la promotion medicale, la representation et un suivi terrain adapte."
	canonical="https://dasmarkpharma.ci/distribution-pharmaceutique-abidjan/"
	structuredData={localSchema}
>
	<Header />
	<main id="top">
		<section class="section">
			<div class="container seo-page">
				<h1>Accompagnement pharmaceutique a Abidjan</h1>
				<p>
					DASMARK PHARMA accompagne les etablissements de sante et les laboratoires a Abidjan
					avec une approche terrain orientee visibilite, coordination et conformite.
				</p>

				<h2>Accompagnement des acteurs de sante a Abidjan</h2>
				<h3>Promotion medicale et representation locale</h3>
				<p>
					Nous renforcons la presence des produits et des laboratoires avec un travail de
					proximite adapte au contexte d Abidjan.
				</p>
				<h3>Affaires reglementaires et coordination terrain</h3>
				<p>
					Nous aidons a structurer les demarches, les prises de contact et le suivi
					operationnel avec les structures de sante.
				</p>

				<h2>Coordonnees locales</h2>
				<p>
					Adresse: Cocody Angre Djrorobite 2, derriere la pharmacie Sainte Clementine, Abidjan.
					Telephone: +225 07 49 94 27 44.
				</p>

				<h2>Pages associees</h2>
				<p>
					Consultez aussi notre page
					<a href="/fournisseur-pharmaceutique-cote-divoire/">accompagnement pharmaceutique en Cote d Ivoire</a>
					et nos <a href="/services/">services pharmaceutiques en Cote d Ivoire</a>.
				</p>
			</div>
		</section>
	</main>
</Layout>

<style>
	.seo-page h1,
	.seo-page h2,
	.seo-page h3 {
		line-height: 1.25;
	}

	.seo-page h1 {
		margin-bottom: 0.8rem;
	}

	.seo-page h2 {
		margin-top: 1.6rem;
		margin-bottom: 0.6rem;
	}

	.seo-page h3 {
		margin-top: 1rem;
		margin-bottom: 0.4rem;
		font-size: 1.05rem;
	}

	.seo-page p {
		margin: 0;
		max-width: 70ch;
	}

	.seo-page a {
		color: #0e5ea8;
		text-decoration: underline;
		font-weight: 700;
	}
</style>
