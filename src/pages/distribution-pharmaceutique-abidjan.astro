---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const localSchema = {
	'@context': 'https://schema.org',
	'@type': 'Service',
	name: 'Accompagnement pharmaceutique à Abidjan',
	provider: {
		'@type': 'Organization',
		name: 'DASMARK PHARMA',
		url: 'https://dasmarkpharma.ci'
	},
	areaServed: ['Abidjan', "Côte d'Ivoire"]
};
---

<Layout
	title="Accompagnement pharmaceutique à Abidjan | DASMARK PHARMA"
	description="DASMARK PHARMA accompagne les laboratoires et acteurs de santé à Abidjan avec la promotion médicale, la représentation et un suivi terrain adapté."
	canonical="https://dasmarkpharma.ci/distribution-pharmaceutique-abidjan/"
	structuredData={localSchema}
>
	<Header />
	<main id="top">
		<section class="section">
			<div class="container seo-page">
				<h1>Accompagnement pharmaceutique à Abidjan</h1>
				<p>
					DASMARK PHARMA accompagne les établissements de santé et les laboratoires à Abidjan
					avec une approche terrain orientée vers la visibilité, la coordination et la conformité.
				</p>

				<h2>Accompagnement des acteurs de santé à Abidjan</h2>
				<h3>Promotion médicale et représentation locale</h3>
				<p>
					Nous renforçons la présence des produits et des laboratoires avec un travail de
					proximité adapté au contexte d'Abidjan.
				</p>
				<h3>Affaires réglementaires et coordination terrain</h3>
				<p>
					Nous aidons à structurer les démarches, les prises de contact et le suivi
					opérationnel avec les structures de santé.
				</p>

				<h2>Coordonnées locales</h2>
				<p>
					Adresse : Cocody Angré Djorobité 2, derrière la pharmacie Sainte Clémentine, Abidjan.
					Téléphone : +225 07 49 94 27 44.
				</p>

				<h2>Pages associées</h2>
				<p>
					Consultez aussi notre page
					<a href="/fournisseur-pharmaceutique-cote-divoire/">accompagnement pharmaceutique en Côte d'Ivoire</a>
					et nos <a href="/services/">services pharmaceutiques en Côte d'Ivoire</a>.
				</p>
			</div>
		</section>
	</main>
</Layout>

<style>
	.seo-page h1,
	.seo-page h2,
	.seo-page h3 {
		line-height: 1.25;
	}

	.seo-page h1 {
		margin-bottom: 0.8rem;
	}

	.seo-page h2 {
		margin-top: 1.6rem;
		margin-bottom: 0.6rem;
	}

	.seo-page h3 {
		margin-top: 1rem;
		margin-bottom: 0.4rem;
		font-size: 1.05rem;
	}

	.seo-page p {
		margin: 0;
		max-width: 70ch;
	}

	.seo-page a {
		color: #0e5ea8;
		text-decoration: underline;
		font-weight: 700;
	}
</style>
