---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

const productSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'Produits pharmaceutiques B2B',
	url: 'https://dasmarkpharma.ci/produits/'
};
---

<Layout
	title="Produits pharmaceutiques B2B | DASMARK PHARMA"
	description="Catalogue B2B de produits pharmaceutiques pour pharmacies, hopitaux, cliniques et laboratoires en Cote d Ivoire."
	canonical="https://dasmarkpharma.ci/produits/"
	structuredData={productSchema}
>
	<Header />
	<main id="top">
		<section class="section">
			<div class="container seo-page">
				<h1>Produits pharmaceutiques pour professionnels de sante</h1>
				<p>
					Notre portefeuille est organise pour les structures de soins qui recherchent un
					fournisseur pharmaceutique Afrique de l Ouest fiable.
				</p>

				<h2>Categories de produits B2B</h2>
				<h3>Gammes pour hopitaux et cliniques</h3>
				<p>
					References pour besoins institutionnels avec pilotage de la disponibilite en Cote d Ivoire.
				</p>
				<h3>Gammes pour pharmacies de ville</h3>
				<p>
					Selection de produits adaptes aux besoins de distribution medicaments Abidjan.
				</p>

				<h2>Demande commerciale</h2>
				<p>
					Pour obtenir un accompagnement dedie,
					<a href="/contact/">contactez notre equipe de distribution pharmaceutique en Cote d Ivoire</a>.
				</p>

				<div class="seo-cta-row">
					<a class="seo-btn" href="/contact/">Contacter le service B2B</a>
					<a class="seo-btn seo-btn-alt" href="/services/">Voir les services</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.seo-page h1,
	.seo-page h2,
	.seo-page h3 {
		line-height: 1.25;
	}

	.seo-page h1 {
		margin-bottom: 0.8rem;
	}

	.seo-page h2 {
		margin-top: 1.6rem;
		margin-bottom: 0.6rem;
	}

	.seo-page h3 {
		margin-top: 1rem;
		margin-bottom: 0.4rem;
		font-size: 1.05rem;
	}

	.seo-page p {
		margin: 0;
		max-width: 70ch;
	}

	.seo-page a {
		color: #0e5ea8;
		text-decoration: underline;
		font-weight: 700;
	}

	.seo-cta-row {
		display: flex;
		gap: 0.8rem;
		margin-top: 1.6rem;
		flex-wrap: wrap;
	}

	.seo-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.7rem 1.1rem;
		border-radius: 999px;
		background: #0e5ea8;
		color: #fff;
		font-weight: 700;
		text-decoration: none;
	}

	.seo-btn-alt {
		background: #fff;
		color: #0e5ea8;
	}
</style>
