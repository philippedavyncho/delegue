---
interface Props {
	name: 'stethoscope' | 'pulse' | 'map';
}

const { name } = Astro.props;
---

<span class="icon-badge" aria-hidden="true">
	{
		name === 'stethoscope' && (
			<svg viewBox="0 0 24 24" fill="none">
				<path d="M7 3v5a5 5 0 0 0 10 0V3" />
				<path d="M7 6H4v2a6 6 0 0 0 12 0V6" />
				<path d="M16 14v2a4 4 0 1 0 8 0 4 4 0 0 0-4-4h-1" />
			</svg>
		)
	}
	{
		name === 'pulse' && (
			<svg viewBox="0 0 24 24" fill="none">
				<path d="M2 12h4l2.2-4.5L12 18l2.6-6h7.4" />
			</svg>
		)
	}
	{
		name === 'map' && (
			<svg viewBox="0 0 24 24" fill="none">
				<path d="M9 18 3 21V6l6-3 6 3 6-3v15l-6 3-6-3Z" />
				<path d="M9 3v15M15 6v15" />
			</svg>
		)
	}
</span>

<style>
	.icon-badge {
		display: inline-flex;
		width: 3.4rem;
		height: 3.4rem;
		align-items: center;
		justify-content: center;
		border-radius: 1.1rem;
		background: linear-gradient(145deg, rgba(14, 94, 168, 0.14), rgba(30, 155, 132, 0.16));
		color: var(--primary);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
	}

	svg {
		width: 1.55rem;
		height: 1.55rem;
		stroke: currentColor;
		stroke-width: 1.7;
		stroke-linecap: round;
		stroke-linejoin: round;
	}
</style>
