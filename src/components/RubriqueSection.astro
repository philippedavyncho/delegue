---

<section class="rubrique section" id="rubrique">
	<div class="container rubrique-shell">
		<div class="rubrique-heading">
			<span class="rubrique-kicker">Rubrique</span>
			<h2>Produits en vedette</h2>
			<p>Un carrousel pret a accueillir vos images produits avec leur texte de presentation.</p>
		</div>

		<div class="splide rubrique-carousel" aria-label="Carrousel des produits">
			<div class="splide__track">
				<ul class="splide__list">
					{
						slides.map((slide, index) => (
							<li class="splide__slide">
								<article class="rubrique-card">
									<div class="rubrique-visual" aria-label={`Emplacement image produit ${index + 1}`}>
										<div class="visual-placeholder">
											<svg viewBox="0 0 24 24" aria-hidden="true">
												<path d="M5 4.5A2.5 2.5 0 0 0 2.5 7v10A2.5 2.5 0 0 0 5 19.5h14a2.5 2.5 0 0 0 2.5-2.5V7A2.5 2.5 0 0 0 19 4.5H5Zm0 1.5h14c.55 0 1 .45 1 1v6.01l-2.63-2.62a1.5 1.5 0 0 0-2.12 0l-1.88 1.88-2.13-2.13a1.5 1.5 0 0 0-2.12 0L4 15.26V7c0-.55.45-1 1-1Zm14 12H5c-.55 0-1-.45-1-1v-.62l4.3-4.3l2.13 2.13a1.5 1.5 0 0 0 2.12 0l1.88-1.88L20 15.13V17c0 .55-.45 1-1 1ZM8 10.25A1.75 1.75 0 1 0 8 6.75a1.75 1.75 0 0 0 0 3.5Z"></path>
											</svg>
											<span>Image produit a ajouter</span>
										</div>
									</div>

									<div class="rubrique-copy">
										<span class="rubrique-index">0{index + 1}</span>
										<h3>{slide.title}</h3>
										<p>{slide.text}</p>
									</div>
								</article>
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</div>
</section>

<style>
	.rubrique {
		padding-top: 1rem;
	}

	.rubrique-shell {
		padding: 1.3rem 1.2rem 1.8rem;
		border-radius: 3rem;
		background: rgba(255, 255, 255, 0.58);
		border: 1px solid rgba(255, 255, 255, 0.74);
		box-shadow: 0 24px 68px rgba(166, 156, 235, 0.14);
		position: relative;
		overflow: hidden;
	}

	.rubrique-shell::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			radial-gradient(40% 50% at 10% 20%, rgba(117, 179, 255, 0.15), transparent 70%),
			radial-gradient(36% 46% at 90% 80%, rgba(178, 151, 255, 0.16), transparent 70%);
		pointer-events: none;
	}

	.rubrique-heading,
	.rubrique-carousel {
		position: relative;
		z-index: 1;
	}

	.rubrique-heading {
		max-width: 42rem;
		margin-bottom: 1.5rem;
	}

	.rubrique-kicker {
		display: inline-flex;
		padding: 0.38rem 0.72rem;
		border-radius: 999px;
		background: rgba(14, 94, 168, 0.1);
		color: #0e5ea8;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.rubrique-heading h2 {
		margin: 0.85rem 0 0;
		font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1;
		letter-spacing: -0.05em;
		color: #30449f;
	}

	.rubrique-heading p {
		margin: 0.9rem 0 0;
		color: #66739e;
	}

	.rubrique-card {
		display: grid;
		grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
		gap: 1.2rem;
		align-items: stretch;
		padding: 0.35rem;
	}

	.rubrique-visual,
	.rubrique-copy {
		border-radius: 2rem;
	}

	.rubrique-visual {
		min-height: 390px;
		padding: 1rem;
		border: 2px dashed rgba(108, 139, 219, 0.4);
		background:
			linear-gradient(135deg, rgba(233, 240, 255, 0.95), rgba(248, 250, 255, 0.82)),
			radial-gradient(circle at top right, rgba(140, 173, 255, 0.18), transparent 32%);
	}

	.visual-placeholder {
		display: grid;
		place-items: center;
		gap: 0.85rem;
		width: 100%;
		height: 100%;
		border-radius: 1.55rem;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.72), rgba(240, 245, 255, 0.88)),
			repeating-linear-gradient(
				45deg,
				rgba(118, 152, 232, 0.08) 0,
				rgba(118, 152, 232, 0.08) 16px,
				rgba(255, 255, 255, 0.14) 16px,
				rgba(255, 255, 255, 0.14) 32px
			);
		text-align: center;
		color: #6880b2;
	}

	.visual-placeholder svg {
		width: 4rem;
		height: 4rem;
		fill: currentColor;
	}

	.visual-placeholder span {
		font-size: 1rem;
		font-weight: 700;
	}

	.rubrique-copy {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 1.5rem;
		background:
			radial-gradient(circle at top right, rgba(255, 255, 255, 0.26), transparent 25%),
			linear-gradient(135deg, rgba(87, 121, 229, 0.94), rgba(143, 119, 238, 0.92));
		color: #fff;
		box-shadow: 0 20px 48px rgba(101, 103, 202, 0.2);
	}

	.rubrique-index {
		display: inline-flex;
		margin-bottom: 0.8rem;
		font-size: 0.88rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.78);
	}

	.rubrique-copy h3 {
		margin: 0;
		font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
		font-size: clamp(1.8rem, 3vw, 2.5rem);
		line-height: 1.02;
		letter-spacing: -0.05em;
	}

	.rubrique-copy p {
		margin: 1rem 0 0;
		font-size: 1rem;
		color: rgba(255, 255, 255, 0.9);
	}

	.rubrique-carousel :global(.splide__pagination) {
		bottom: -1.1rem;
	}

	.rubrique-carousel :global(.splide__pagination__page) {
		width: 0.72rem;
		height: 0.72rem;
		background: rgba(77, 103, 180, 0.26);
		opacity: 1;
	}

	.rubrique-carousel :global(.splide__pagination__page.is-active) {
		background: #4168c6;
		transform: scale(1.15);
	}

	.rubrique-carousel :global(.splide__slide) {
		transition-timing-function: ease-in-out;
	}

	.rubrique-carousel :global(.splide__slide > *) {
		will-change: opacity, transform;
	}

	@media (max-width: 900px) {
		.rubrique-card {
			grid-template-columns: 1fr;
		}

		.rubrique-visual {
			min-height: 300px;
		}
	}

	@media (max-width: 640px) {
		.rubrique-shell {
			padding: 1rem 1rem 1.5rem;
			border-radius: 1.6rem;
		}

		.rubrique-visual,
		.rubrique-copy {
			border-radius: 1.4rem;
		}

		.rubrique-visual {
			min-height: 220px;
			padding: 0.8rem;
		}

		.rubrique-copy {
			padding: 1.15rem;
		}
	}
</style>
