---
import { readdirSync } from 'node:fs';
import { extname, resolve } from 'node:path';

const imageExtensions = new Set(['.jpg', '.jpeg', '.png', '.webp', '.avif']);

const readPublicImages = (folder) =>
	readdirSync(resolve(process.cwd(), 'public', folder), { withFileTypes: true })
		.filter((entry) => entry.isFile() && imageExtensions.has(extname(entry.name).toLowerCase()))
		.map((entry) => entry.name)
		.sort((left, right) => left.localeCompare(right, undefined, { numeric: true, sensitivity: 'base' }))
		.map((name) => `/${folder}/${encodeURIComponent(name)}`);

const partners = [
	{
		key: 'galpha',
		name: 'laboratoire GALPHA',
		logo: '/dsph.png',
		logoAlt: 'Logo GALPHA',
		badgeClass: 'partner-badge-galpha',
		images: readPublicImages('galpha')
	},
	{
		key: 'axa',
		name: 'laboratoire AXA PARENTERALS',
		logo: '/partal.png',
		logoAlt: 'Logo AXA PARENTERALS',
		badgeClass: 'partner-badge-axa',
		images: readPublicImages('axa')
	}
];

const maxImageCount = Math.max(...partners.map((partner) => partner.images.length), 0);

const slides = [];

for (let imageIndex = 0; imageIndex < maxImageCount; imageIndex += 1) {
	for (const partner of partners) {
		const image = partner.images[imageIndex];

		if (!image) continue;

		slides.push({
			...partner,
			image,
			imageIndex
		});
	}
}
---

<section class="rubrique section" id="rubrique">
	<div class="container rubrique-shell">
		<div class="rubrique-heading">
			<span class="rubrique-kicker">Rubrique</span>
			<h2>Nos solutions pharmaceutiques</h2>
			<p>Nous valorisons les innovations et médicaments de nos laboratoires partenaires en proposant aux acteurs de santé des solutions fiables, performantes et adaptées aux exigences du marché.</p>
		</div>

		<div class="splide rubrique-carousel" aria-label="Carrousel des laboratoires partenaires">
			<div class="splide__track">
				<ul class="splide__list">
					{
						slides.map((slide, index) => (
							<li class="splide__slide">
								<article class="rubrique-card">
									<div class="rubrique-visual" aria-label={`Visuel ${slide.imageIndex + 1} du ${slide.name}`}>
										<div class="rubrique-visual-frame">
											<img
												src={slide.image}
												alt={`Produit ${slide.imageIndex + 1} du ${slide.name}`}
												loading={index < 2 ? 'eager' : 'lazy'}
												decoding="async"
											/>
										</div>
									</div>

									<div class="rubrique-copy">
										<div class="rubrique-partner-card">
											<span class:list={['partner-badge', slide.badgeClass]}>
												<img src={slide.logo} alt={slide.logoAlt} />
											</span>

											<div class="rubrique-partner-copy">
												<strong>{slide.name}</strong>
												<small>Partenaire sante</small>
											</div>
										</div>
									</div>
								</article>
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</div>
</section>

<style>
	.rubrique {
		padding-top: 1rem;
	}

	.rubrique-shell {
		padding: 1.2rem 1.2rem 2rem;
		min-height: 640px;
		border-radius: 3rem;
		background: rgba(255, 255, 255, 0.64);
		border: 1px solid rgba(255, 255, 255, 0.86);
		box-shadow:
			0 28px 78px rgba(136, 145, 208, 0.16),
			inset 0 1px 0 rgba(255, 255, 255, 0.78);
		position: relative;
		overflow: hidden;
	}

	.rubrique-shell::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			radial-gradient(40% 50% at 10% 20%, rgba(117, 179, 255, 0.15), transparent 70%),
			radial-gradient(36% 46% at 90% 80%, rgba(178, 151, 255, 0.16), transparent 70%);
		pointer-events: none;
	}

	.rubrique-shell::after {
		content: '';
		position: absolute;
		inset: auto 4% 1.1rem 4%;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(122, 144, 220, 0.22), transparent);
		pointer-events: none;
	}

	.rubrique-heading,
	.rubrique-carousel {
		position: relative;
		z-index: 1;
	}

	.rubrique-carousel {
		padding-bottom: 1.8rem;
	}

	.rubrique-heading {
		max-width: 42rem;
		margin-bottom: 1.5rem;
	}

	.rubrique-kicker {
		display: inline-flex;
		padding: 0.38rem 0.72rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid rgba(152, 171, 234, 0.32);
		box-shadow: 0 10px 24px rgba(118, 130, 198, 0.08);
		color: #0e5ea8;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.rubrique-heading h2 {
		margin: 0.85rem 0 0;
		text-align: left;
		font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1;
		letter-spacing: -0.05em;
		color: #30449f;
	}

	.rubrique-heading p {
		margin: 0.9rem 0 0;
		max-width: 62ch;
		color: #66739e;
	}

	.rubrique-card {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(280px, 1fr);
		gap: 1.1rem;
		align-items: stretch;
		padding: 0.2rem;
		height: 400px;
	}

	.rubrique-visual,
	.rubrique-copy {
		border-radius: 2.1rem;
	}

	.rubrique-visual {
		position: relative;
		height: 400px;
		padding: 0.6rem;
		border: 1px solid rgba(152, 169, 228, 0.34);
		background:
			linear-gradient(145deg, rgba(243, 247, 255, 0.98), rgba(236, 242, 255, 0.92)),
			radial-gradient(circle at top right, rgba(140, 173, 255, 0.14), transparent 34%);
		box-shadow:
			0 20px 44px rgba(112, 125, 188, 0.14),
			inset 0 1px 0 rgba(255, 255, 255, 0.95);
		overflow: hidden;
	}

	.rubrique-visual::after {
		content: '';
		position: absolute;
		inset: 0.65rem;
		border-radius: 1.6rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.24), transparent 28%);
		pointer-events: none;
	}

	.rubrique-visual-frame {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
		padding: 0.75rem;
		border-radius: 1.55rem;
		background: #fff;
		border: 1px solid rgba(222, 228, 244, 0.95);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.98),
			0 8px 24px rgba(118, 130, 190, 0.08);
		overflow: hidden;
	}

	.rubrique-visual img {
		display: block;
		width: auto;
		height: auto;
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
		object-position: center;
	}

	.rubrique-copy {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: stretch;
		gap: 0.8rem;
		padding: 1.15rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(248, 250, 255, 0.9));
		border: 1px solid rgba(214, 223, 246, 0.92);
		box-shadow:
			0 22px 46px rgba(109, 117, 174, 0.12),
			inset 0 1px 0 rgba(255, 255, 255, 0.96);
		overflow: hidden;
	}

	.rubrique-copy::before {
		content: '';
		position: absolute;
		inset: 0 0 auto 0;
		height: 4px;
		background: linear-gradient(90deg, rgba(94, 126, 222, 0.92), rgba(116, 184, 195, 0.82));
	}

	.rubrique-partner-card {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		width: 100%;
		flex: 1;
		max-width: none;
		padding: 1rem 1.05rem;
		border-radius: 1.8rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 249, 255, 0.9));
		border: 1px solid rgba(221, 227, 244, 0.96);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.98),
			0 14px 34px rgba(108, 118, 176, 0.08);
	}

	.partner-badge {
		display: inline-flex;
		flex: 0 0 auto;
		align-items: center;
		justify-content: center;
		width: 5.6rem;
		height: 5.6rem;
		padding: 0.4rem;
		border-radius: 999px;
		border: 3px solid rgba(179, 123, 168, 0.42);
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 248, 255, 0.9));
		box-shadow:
			0 12px 26px rgba(111, 120, 181, 0.12),
			inset 0 1px 0 rgba(255, 255, 255, 0.98);
	}

	.partner-badge img {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.partner-badge-galpha {
		border-color: rgba(90, 173, 110, 0.42);
	}

	.partner-badge-axa {
		border-color: rgba(179, 123, 168, 0.42);
	}

	.rubrique-partner-copy strong,
	.rubrique-partner-copy small {
		display: block;
		text-align: left;
	}

	.rubrique-partner-copy {
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.rubrique-partner-copy strong {
		font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
		font-size: clamp(1.24rem, 1.75vw, 1.6rem);
		line-height: 1.08;
		letter-spacing: -0.04em;
		color: #394c93;
	}

	.rubrique-partner-copy small {
		margin-top: 0.3rem;
		font-size: 0.88rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #7683af;
	}

	.rubrique-carousel :global(.splide__pagination) {
		bottom: 0.15rem;
	}

	.rubrique-carousel :global(.splide__pagination__page) {
		width: 0.72rem;
		height: 0.72rem;
		background: rgba(77, 103, 180, 0.26);
		opacity: 1;
	}

	.rubrique-carousel :global(.splide__pagination__page.is-active) {
		background: #4168c6;
		transform: scale(1.15);
	}

	.rubrique-carousel :global(.splide__track),
	.rubrique-carousel :global(.splide__list),
	.rubrique-carousel :global(.splide__slide) {
		height: 400px;
	}

	.rubrique-carousel :global(.splide__slide) {
		transition-timing-function: ease-in-out;
	}

	.rubrique-carousel :global(.splide__slide > *) {
		will-change: opacity, transform;
	}

	@media (max-width: 900px) {
		.rubrique-shell {
			min-height: auto;
		}

		.rubrique-card {
			grid-template-columns: 1fr;
			height: auto;
		}

		.rubrique-visual {
			height: 300px;
		}

		.rubrique-visual img {
			max-width: 100%;
			height: 100%;
			max-height: none;
		}

		.rubrique-carousel :global(.splide__track),
		.rubrique-carousel :global(.splide__list),
		.rubrique-carousel :global(.splide__slide) {
			height: auto;
		}
	}

	@media (max-width: 640px) {
		.rubrique-shell {
			padding: 1rem 1rem 1.4rem;
			min-height: auto;
			border-radius: 1.6rem;
		}

		.rubrique-carousel {
			padding-bottom: 1.5rem;
		}

		.rubrique-visual,
		.rubrique-copy,
		.rubrique-partner-card {
			border-radius: 1.4rem;
		}

		.rubrique-visual {
			height: 240px;
			padding: 0.55rem;
		}

		.rubrique-visual-frame {
			padding: 0.65rem;
		}

		.rubrique-visual img {
			width: auto;
			height: auto;
			max-width: 100%;
			max-height: 100%;
		}

		.rubrique-copy {
			padding: 0.9rem;
		}

		.rubrique-partner-card {
			flex-direction: column;
			text-align: center;
		}

		.rubrique-partner-copy strong,
		.rubrique-partner-copy small {
			text-align: center;
		}
	}
</style>
