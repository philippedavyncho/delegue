<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	const initApp = () => {
		document.body.classList.add('is-loading');

		const loader = document.querySelector('[data-loader]');
		const header = document.querySelector('[data-header]');
		const menuToggle = document.querySelector('[data-nav-toggle]');
		const mobileNav = document.querySelector('[data-mobile-nav]');
		const mobileLinks = mobileNav?.querySelectorAll('a') ?? [];
		let mobileTimeline;

		if (loader instanceof HTMLElement) {
			const hideLoader = () => {
				loader.classList.add('is-hidden');
				document.body.classList.remove('is-loading');
			};

			window.addEventListener('load', () => {
				gsap
					.timeline()
					.from('.loader-mark', { scale: 0.9, opacity: 0, duration: 0.45, ease: 'power2.out' })
					.from('.loader-mark span:first-child', {
						rotate: 180,
						duration: 1.1,
						ease: 'power2.out'
					})
					.from('.loader-mark span:last-child', {
						scale: 0.2,
						opacity: 0,
						duration: 0.35,
						ease: 'back.out(1.8)'
					}, '-=0.9')
					.from('.site-loader p', { y: 10, opacity: 0, duration: 0.35 }, '-=0.5')
					.to(loader, {
						opacity: 0,
						duration: 0.5,
						delay: 0.15,
						onComplete: hideLoader
					});
			}, { once: true });
		} else {
			document.body.classList.remove('is-loading');
		}

		if (header instanceof HTMLElement) {
			const updateHeader = () => {
				header.classList.toggle('is-scrolled', window.scrollY > 18);
			};

			updateHeader();
			window.addEventListener('scroll', updateHeader, { passive: true });
		}

		if (menuToggle instanceof HTMLButtonElement && mobileNav instanceof HTMLElement) {
			mobileTimeline = gsap.timeline({ paused: true });
			mobileTimeline
				.set(mobileNav, { display: 'block', pointerEvents: 'auto' })
				.fromTo(
					mobileNav,
					{ y: -12, opacity: 0 },
					{ y: 0, opacity: 1, duration: 0.28, ease: 'power2.out' }
				)
				.from(
					'.mobile-nav > *',
					{ y: 10, opacity: 0, stagger: 0.05, duration: 0.22, ease: 'power2.out' },
					'-=0.18'
				);

			const toggleMenu = (open) => {
				menuToggle.classList.toggle('is-open', open);
				menuToggle.setAttribute('aria-expanded', String(open));
				document.body.classList.toggle('menu-open', open);

				if (open) {
					mobileTimeline.play(0);
				} else {
					gsap.to(mobileNav, {
						y: -10,
						opacity: 0,
						duration: 0.22,
						ease: 'power2.in',
						onComplete: () => {
							mobileTimeline.pause(0);
							gsap.set(mobileNav, { clearProps: 'all' });
						}
					});
				}
			};

			menuToggle.addEventListener('click', () => {
				const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
				toggleMenu(!isOpen);
			});

			mobileLinks.forEach((link) => link.addEventListener('click', () => toggleMenu(false)));
		}

		gsap
			.timeline({ defaults: { ease: 'power3.out' } })
			.from('.site-header', { y: -18, opacity: 0, duration: 0.8 })
			.from('.hero-copy > *', { y: 22, opacity: 0, stagger: 0.08, duration: 0.7 }, '-=0.35')
			.from('.hero-image-frame', { y: 28, opacity: 0, scale: 0.98, duration: 0.9 }, '-=0.65');

		gsap.utils.toArray('.services-copy, .services-gallery, .about-copy, .about-cards, .partners-shell').forEach((element) => {
			gsap.from(element, {
				y: 30,
				opacity: 0,
				duration: 0.85,
				ease: 'power3.out',
				scrollTrigger: {
					trigger: element,
					start: 'top 84%'
				}
			});
		});
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initApp, { once: true });
	} else {
		initApp();
	}
</script>
