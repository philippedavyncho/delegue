---
import MobileCarousel from './MobileCarousel.astro';
---

<header class="site-header" data-header>
	<div class="container header-inner">
		<a class="brand" href="/" aria-label="Retour à l'accueil">
			<img class="brand-mark" src="/logodasm.png" alt="Logo Dasmark Pharma" />
			<span class="brand-copy">
				<strong>DASMARK PHARMA</strong>
				<small>Les As du Marketing</small>
			</span>
		</a>

		<nav class="desktop-nav" aria-label="Navigation principale">
			<a href="/">Accueil</a>
			<a href="/a-propos/">À propos</a>
			<a href="/services/">Services</a>
			<a href="/contact/">Contact</a>
		</nav>

		<div class="header-actions">
			<a class="header-phone" href="https://wa.me/2250749942744" aria-label="Contacter Dasmark Pharma sur WhatsApp">
