				</svg>
			</a>
			<button class="menu-toggle" type="button" data-nav-toggle aria-expanded="false" aria-label="Ouvrir le menu">
				<span></span>
				<span></span>
			</button>
		</div>
	</div>

	<div class="container mobile-stage">
		<MobileCarousel compact={true} />

		<div class="mobile-panel" data-mobile-nav>
			<nav class="mobile-nav" aria-label="Navigation mobile">
				<a href="/">Accueil</a>
				<a href="/a-propos/">À propos</a>
				<a href="/services/">Services</a>
				<a href="/contact/">Contact</a>
				<a class="header-phone mobile-phone" href="https://wa.me/2250749942744" aria-label="Contacter Dasmark Pharma sur WhatsApp">
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path d="M20.52 3.48A11.86 11.86 0 0 0 12.07 0C5.53 0 .2 5.33.2 11.87c0 2.1.55 4.15 1.59 5.95L0 24l6.39-1.67a11.8 11.8 0 0 0 5.67 1.45h.01c6.54 0 11.87-5.33 11.87-11.87 0-3.17-1.24-6.15-3.42-8.43Zm-8.45 18.3h-.01a9.9 9.9 0 0 1-5.04-1.38l-.36-.21-3.79.99 1.01-3.69-.23-.38a9.87 9.87 0 0 1-1.51-5.24c0-5.45 4.44-9.88 9.9-9.88 2.64 0 5.11 1.03 6.98 2.9a9.8 9.8 0 0 1 2.89 6.98c0 5.45-4.44 9.9-9.88 9.9Zm5.42-7.42c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.46-.88-.78-1.48-1.75-1.66-2.05-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.48-.5-.67-.5h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.5s1.07 2.9 1.22 3.1c.15.2 2.1 3.21 5.09 4.5.71.31 1.27.5 1.7.64.71.23 1.36.2 1.87.12.57-.08 1.77-.72 2.02-1.42.25-.7.25-1.29.17-1.42-.07-.12-.27-.2-.57-.35Z"></path>
					</svg>
				</a>
			</nav>
		</div>
	</div>
</header>

<style>
	.site-header {
		z-index: 40;
		padding-top: 1rem;
		overflow: visible;
	}

	.header-inner {
		position: sticky;
		top: 0;
		z-index: 40;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.25rem;
		padding: 0.9rem 1.3rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.18);
		border: 1px solid rgba(255, 255, 255, 0.36);
		backdrop-filter: blur(20px);
		box-shadow: 0 18px 50px rgba(111, 94, 218, 0.16);
	}

	.site-header.is-scrolled .header-inner {
		background: rgba(255, 255, 255, 0.28);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		min-width: 0;
	}

	.brand-mark {
		width: 4.5rem;
		height: 4.5rem;
		object-fit: cover;
		
	}

	.brand-copy {
		display: grid;
		line-height: 1.1;
	}

	.brand-copy strong {
		font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
		font-size: 1.15rem;
		color: #fff;
		letter-spacing: -0.03em;
	}

	.brand-copy small {
		font-size: 0.82rem;
		color: rgba(255, 255, 255, 0.82);
	}

	.desktop-nav {
		display: inline-flex;
		align-items: center;
		gap: 1.6rem;
		color: rgba(255, 255, 255, 0.9);
		font-size: 0.96rem;
	}

	.desktop-nav a {
		opacity: 0.88;
		transition: opacity 180ms ease, transform 180ms ease;
	}

	.desktop-nav a:hover {
		opacity: 1;
		transform: translateY(-1px);
	}

	.header-actions {
		display: flex;
		align-items: center;
		gap: 0.9rem;
	}

	.header-phone {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.18);
		border: 1px solid rgba(255, 255, 255, 0.34);
		color: #00c853;
		box-shadow: 0 10px 24px rgba(0, 200, 83, 0.18);
		transition: transform 180ms ease, box-shadow 180ms ease, filter 180ms ease;
	}

	.header-phone svg {
		width: 1.35rem;
		height: 1.35rem;
		fill: currentColor;
		filter: none;
	}

	.header-phone:hover {
		transform: translateY(-2px);
		box-shadow: 0 14px 28px rgba(0, 200, 83, 0.22);
		filter: none;
	}

	.menu-toggle {
		display: none;
		position: relative;
		width: 3rem;
		height: 3rem;
		border: 0;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.16);
		color: #fff;
	}

	.menu-toggle span {
		position: absolute;
		left: 0.92rem;
		width: 1.16rem;
		height: 2px;
		border-radius: 999px;
		background: currentColor;
		transition: transform 220ms ease, top 220ms ease;
	}

	.menu-toggle span:first-child { top: 1.12rem; }
	.menu-toggle span:last-child { top: 1.72rem; }
	.menu-toggle.is-open span:first-child { top: 1.42rem; transform: rotate(45deg); }
	.menu-toggle.is-open span:last-child { top: 1.42rem; transform: rotate(-45deg); }

	.mobile-panel {
		display: none;
		position: absolute;
		inset: 0;
		z-index: 3;
		padding: 1rem;
		border-radius: 1.8rem;
		background: rgba(255, 255, 255, 0.22);
		border: 1px solid rgba(255, 255, 255, 0.34);
		backdrop-filter: blur(18px);
		opacity: 0;
		transform: translateY(-12px);
		pointer-events: none;
	}

	.mobile-stage {
		display: none;
		position: relative;
		margin-top: calc(0.15rem + 10px);
		z-index: 1;
	}

	.mobile-nav {
		display: grid;
		gap: 0.95rem;
		color: #fff;
	}

	.mobile-phone {
		display: inline-flex;
		justify-content: center;
		margin-top: 0.3rem;
	}

	@media (max-width: 980px) {
		.desktop-nav,
		.header-actions .header-phone {
			display: none;
		}

		.menu-toggle,
		.mobile-stage,
		.mobile-panel {
			display: block;
		}
	}

	@media (max-width: 640px) {
		.site-header {
			padding-top: 0.7rem;
		}

		.header-inner {
			border-radius: 1.6rem;
			padding: 0.85rem 1rem;
		}

		.brand-copy strong {
			font-size: 1rem;
		}

		.mobile-stage {
			margin-top: calc(0.1rem + 10px);
		}
	}
</style>
